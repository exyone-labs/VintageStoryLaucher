<UserControl x:Class="VSL.UI.Views.Pages.ConsolePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1180">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,0,12">
            <TextBlock Style="{DynamicResource VslPageTitleStyle}" Text="控制台与日志" />
            <TextBlock Style="{DynamicResource VslPageSubTitleStyle}"
                       Text="实时查看输出并发送控制台命令。"/>
        </StackPanel>

        <ui:Card Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{DynamicResource VslActionBarHostStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0">
                            <Button Content="启动服务器"
                                    Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding StartServerCommand}" />
                            <Button Content="停止服务器"
                                    Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding StopServerCommand}" />
                        </WrapPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <CheckBox Content="追踪"
                                      Margin="0,0,8,8"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsConsoleAutoFollow}" />
                            <Button Content="下载"
                                    Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding DownloadConsoleLogCommand}" />
                            <Button Content="清空"
                                    Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding ClearConsoleCommand}" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        CornerRadius="4"
                        ClipToBounds="True"
                        Background="{DynamicResource VslCodePaneBrush}"
                        BorderBrush="{DynamicResource VslPanelBorderBrush}"
                        BorderThickness="1">
                    <ListBox x:Name="ConsoleList"
                         Style="{StaticResource VslConsoleListBoxStyle}"
                         ItemContainerStyle="{StaticResource VslConsoleListBoxItemStyle}"
                         ItemsSource="{Binding ConsoleLines}"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         Padding="4" />
                </Border>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="32"
                             Padding="8,4"
                             Text="{Binding ConsoleInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="发送命令"
                            Width="100"
                            Height="32"
                            Margin="8,0,0,0"
                            Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding SendConsoleCommandCommand}" />
                </Grid>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>


