<UserControl x:Class="VSL.UI.Views.Pages.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1180">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,0,12">
            <TextBlock Style="{DynamicResource VslPageTitleStyle}" Text="Mod 管理" />
            <TextBlock Style="{DynamicResource VslPageSubTitleStyle}"
                       Text="导入 Mod、检查依赖状态，并切换启用/禁用。"/>
        </StackPanel>

        <ui:Card Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{DynamicResource VslActionBarHostStyle}">
                    <WrapPanel>
                        <Button Content="刷新 Mod 列表"
                                Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding RefreshModsCommand}" />
                        <Button Content="导入 Mod ZIP"
                                Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding ImportModZipCommand}" />
                        <Button Content="启用/禁用选中"
                                Style="{StaticResource VslToolbarButtonStyle}" Command="{Binding ToggleSelectedModCommand}" />
                    </WrapPanel>
                </Border>

                <Grid Grid.Row="1">
                    <ListView x:Name="ModsList"
                              Style="{StaticResource VslListViewStyle}"
                              ItemContainerStyle="{StaticResource VslListViewItemStyle}"
                              ItemsSource="{Binding Mods}"
                              SelectedItem="{Binding SelectedMod}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource VslGridViewHeaderStyle}" />
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource VslListViewItemStyle}" />
                        </ListView.Resources>
                        <ListView.View>
                            <GridView ColumnHeaderContainerStyle="{StaticResource VslGridViewHeaderStyle}">
                                <GridViewColumn Header="ModId" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding ModId}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="版本" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding Version}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="禁用" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding IsDisabled}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="状态" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding Status}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="依赖" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding DependenciesText}"
                                                       ToolTip="{Binding DependenciesText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="依赖问题" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource VslTableCellTextStyle}"
                                                       Text="{Binding IssuesText}"
                                                       ToolTip="{Binding IssuesText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock Text="暂无 Mod，可先导入一个 ZIP 包。">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource VslEmptyHintStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ModsList, Path=HasItems}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>




