<ui:FluentWindow x:Class="VSL.UI.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:VSL.UI.Views.Pages"
                 mc:Ignorable="d"
                 Title="VintageStoryServerLauncher (VSL)"
                 Width="1600"
                 Height="980"
                 MinWidth="1320"
                 MinHeight="820"
                 Background="{DynamicResource VslAppBackgroundBrush}"
                 Icon="{DynamicResource VslAppLogoImage}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Margin="14,8,14,8"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     ShowClose="False"
                     Title="Vintage Story Server Launcher">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="{DynamicResource VslAppLogoImage}" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <Border Height="30" VerticalAlignment="Center" Background="Transparent">
                    <TextBlock Text="VSL 1.0" Opacity="0.7" VerticalAlignment="Center" />
                </Border>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource VslTitleBarActionButtonStyle}" Command="{Binding StartServerCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Style="{StaticResource VslTitleBarSymbolIconStyle}" Symbol="Play20" />
                                <TextBlock VerticalAlignment="Center" Text="启动服务器" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VslTitleBarActionButtonStyle}" Margin="0" Command="{Binding StopServerCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Style="{StaticResource VslTitleBarSymbolIconStyle}" Symbol="Stop20" />
                                <TextBlock VerticalAlignment="Center" Text="停止服务器" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource VslWindowControlButtonStyle}"
                                ToolTip="最小化"
                                Click="WindowMinimizeButton_OnClick">
                            <ui:SymbolIcon Style="{StaticResource VslWindowControlSymbolIconStyle}" Symbol="Subtract20" />
                        </Button>
                        <Button Style="{StaticResource VslWindowControlButtonStyle}"
                                ToolTip="最大化/还原"
                                Click="WindowMaximizeButton_OnClick">
                            <ui:SymbolIcon Style="{StaticResource VslWindowControlSymbolIconStyle}" Symbol="Square20" />
                        </Button>
                        <Button Style="{StaticResource VslWindowControlButtonStyle}"
                                ToolTip="关闭"
                                Click="WindowCloseButton_OnClick">
                            <ui:SymbolIcon Style="{StaticResource VslWindowControlSymbolIconStyle}" Symbol="Dismiss20" />
                        </Button>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="14,0,14,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{DynamicResource VslGlassPanelStyle}"
                    Padding="8"
                    BorderThickness="1,1,0,1">
                <ui:NavigationView x:Name="RootNavigationView"
                                   Background="Transparent"
                                   PaneDisplayMode="Left"
                                   OpenPaneLength="216"
                                   CompactPaneLength="54"
                                   IsPaneVisible="True"
                                   IsPaneOpen="True"
                                   IsPaneToggleVisible="False"
                                   IsBackButtonVisible="Collapsed"
                                   IsFooterSeparatorVisible="True"
                                   Padding="2"
                                   SelectionChanged="RootNavigationView_OnSelectionChanged">
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem x:Name="NavVersionProfiles" Content="版本与档案" Tag="versionprofile" IsActive="True" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="BoxMultiple20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSettings" Content="服务器配置" Tag="settings" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Server20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAdvancedJson" Content="高级 JSON" Tag="advancedjson" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="CodeBlock20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSaves" Content="存档管理" Tag="saves" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Save20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavMods" Content="Mod 管理" Tag="mods" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="PuzzleCube20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavVs2QQConfig" Content="VS2QQ 配置" Tag="vs2qqconfig" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Bot20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.MenuItems>

                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem x:Name="NavConsole" Content="控制台" Tag="console" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="WindowConsole20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavVs2QQRunner" Content="VS2QQ 启动" Tag="vs2qqrunner" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="PlayCircle20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAppSettings" Content="设置" Tag="appsettings" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Settings20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAbout" Content="关于" Tag="about" Click="NavigationItem_OnClick">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Style="{StaticResource VslNavSymbolIconStyle}" Symbol="Info20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>
            </Border>

            <Border Grid.Column="2"
                    Style="{DynamicResource VslGlassPanelStyle}"
                    Padding="12">
                <Grid>
                    <pages:VersionProfilesPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=versionprofile}" />
                    <pages:ServerSettingsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=settings}" />
                    <pages:AdvancedJsonPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=advancedjson}" />
                    <pages:SavesPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=saves}" />
                    <pages:ModsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=mods}" />
                    <pages:Vs2QQConfigPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=vs2qqconfig}" />
                    <pages:ConsolePage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=console}" />
                    <pages:Vs2QQRunnerPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=vs2qqrunner}" />
                    <pages:AppSettingsPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=appsettings}" />
                    <pages:AboutPage Visibility="{Binding SelectedNavKey, Converter={StaticResource NavKeyToVisibilityConverter}, ConverterParameter=about}" />
                </Grid>
            </Border>
        </Grid>

        <ui:SnackbarPresenter x:Name="RootSnackbarPresenter"
                              Grid.Row="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,24,18" />
    </Grid>
</ui:FluentWindow>
